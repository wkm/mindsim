{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'F=$(cat | jq -r .tool_input.file_path); [[ \"$F\" == *.py ]] && uv run ruff check --fix \"$F\" && uv run ruff format \"$F\" || true'",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "linear@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  }
}

box_0 = Box(w=0.0232, l=0.0121, h=0.0225)  # scs_body
fillet_1 = FilletAxis(box_0, axis='z', r=0.0010)
cyl_2 = Cylinder(r=0.0020, h=0.0020)
loc_3 = Locate(cyl_2, pos=(0.0058, 0.0000, 0.0112))
fuse_4 = Fuse(fillet_1, loc_3)
box_5 = Box(w=0.0325, l=0.0121, h=0.0025)
loc_6 = Locate(box_5, pos=(0.0000, 0.0000, 0.0022))
fuse_7 = Fuse(fuse_4, loc_6)
cyl_8 = Cylinder(r=0.0010, h=0.0100)
loc_9 = Locate(cyl_8, pos=(0.0140, 0.0000, 0.0022))
cut_10 = Cut(fuse_7, loc_9)
cyl_11 = Cylinder(r=0.0010, h=0.0100)
loc_12 = Locate(cyl_11, pos=(-0.0140, 0.0000, 0.0022))
cut_13 = Cut(cut_10, loc_12)

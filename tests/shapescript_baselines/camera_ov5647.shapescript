box_0 = Box(w=0.0250, l=0.0240, h=0.0016)
cyl_1 = Cylinder(r=0.0011, h=0.0026)  # mounting_hole
loc_2 = Locate(cyl_1, pos=(-0.0105, -0.0095, 0.0000))
cut_3 = Cut(box_0, loc_2)
copy_4 = Copy(cyl_1)
loc_5 = Locate(copy_4, pos=(0.0105, -0.0095, 0.0000))
cut_6 = Cut(cut_3, loc_5)
copy_7 = Copy(cyl_1)
loc_8 = Locate(copy_7, pos=(-0.0105, 0.0030, 0.0000))
cut_9 = Cut(cut_6, loc_8)
copy_10 = Copy(cyl_1)
loc_11 = Locate(copy_10, pos=(0.0105, 0.0030, 0.0000))
cut_12 = Cut(cut_9, loc_11)
box_13 = Box(w=0.0085, l=0.0085, h=0.0050)
loc_14 = Locate(box_13, pos=(0.0000, 0.0025, 0.0008))
cyl_15 = Cylinder(r=0.0032, h=0.0025)
loc_16 = Locate(cyl_15, pos=(0.0000, 0.0025, 0.0058))
box_17 = Box(w=0.0160, l=0.0020, h=0.0050)
loc_18 = Locate(box_17, pos=(0.0000, -0.0120, 0.0008))
fuse_19 = Fuse(cut_12, loc_14)
fuse_20 = Fuse(fuse_19, loc_16)
fuse_21 = Fuse(fuse_20, loc_18)

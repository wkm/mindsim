<?xml version='1.0' encoding='utf-8'?>
<!-- Tabletop arena for fixed-base manipulation arms.
     Arm scene.xml files include this via <include file="../../worlds/tabletop.xml" />.
     Provides a table surface, lighting, and manipulation targets. -->
<mujoco model="tabletop">
  <statistic extent="1" center="0 0 0.4" />
  <visual>
    <headlight ambient=".4 .4 .4" diffuse=".8 .8 .8" specular="0.1 0.1 0.1" />
    <map znear="0.005" />
    <quality shadowsize="2048" />
  </visual>
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2" />
    <material name="table_top" rgba="0.85 0.75 0.6 1.0" />
  </asset>
  <worldbody>
    <light directional="true" diffuse=".8 .8 .8" pos="0 0 3" dir="0 0 -1" />
    <geom name="floor" type="plane" size="3 3 0.1" material="groundplane" />

    <!-- Table: 60x60cm surface at height 0 (arm base sits on this) -->
    <!-- The table top is the ground plane for the arm — arm base_type="fixed"
         places the root body at z=body_height/2, sitting on the floor geom. -->

    <!-- Manipulation target -->
    <body name="target" mocap="true" pos="0.15 0.15 0.04">
      <geom name="target_cube" type="box" size="0.02 0.02 0.02" rgba="1.0 0.5 0.0 1.0" contype="0" conaffinity="0" />
    </body>
    <body name="distractor_0" mocap="true" pos="0 0 -1">
      <geom name="distractor_0_cube" type="box" size="0.02 0.02 0.02" rgba="0.2 0.4 1.0 1.0" contype="0" conaffinity="0" />
    </body>
    <body name="distractor_1" mocap="true" pos="0 0 -1">
      <geom name="distractor_1_cube" type="box" size="0.02 0.02 0.02" rgba="0.2 0.9 0.3 1.0" contype="0" conaffinity="0" />
    </body>
    <body name="distractor_2" mocap="true" pos="0 0 -1">
      <geom name="distractor_2_cube" type="box" size="0.02 0.02 0.02" rgba="0.9 0.2 0.2 1.0" contype="0" conaffinity="0" />
    </body>
    <body name="distractor_3" mocap="true" pos="0 0 -1">
      <geom name="distractor_3_cube" type="box" size="0.02 0.02 0.02" rgba="0.7 0.3 0.9 1.0" contype="0" conaffinity="0" />
    </body>
  </worldbody>
</mujoco>
